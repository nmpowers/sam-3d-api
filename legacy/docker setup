# 1. Login to Docker
docker login

# 2. Build for SAM 3
# Note: CUDA 12.6 is backward compatible, but we set ARCH_LIST to be safe for RunPod.
docker build \
  -f Dockerfile.sam \
  --build-arg HF_TOKEN="your_hugging_face_token_here" \
  --build-arg TORCH_CUDA_ARCH_LIST="Ampere;Ada" \
  -t nmpowers/sam-3d-api:latest .

# 3. Push to Docker Hub
docker push nmpowers/sam-3d-api:latest